Bootstrap: docker
From: ubuntu:25.04
Stage: build

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PATH="/opt/venv/bin:$PATH"
    export VIRTUAL_ENV="/opt/venv"

%post
    # Update system and install base tools
    apt-get update
    apt-get install -y --no-install-recommends \
        software-properties-common \
        wget \
        curl \
        git \
        ca-certificates \
        build-essential \
        cmake \
        python3-dev \
        python3-pip \
        python3-venv \
        python3-full

    # Add FEniCS PPA and install fenicsx (DOLFINx + all dependencies)
    add-apt-repository -y ppa:fenics-packages/fenics
    apt-get update
    apt-get install -y --no-install-recommends fenicsx

    # Install additional system libraries for plotting (PyVista, Gmsh, etc.)
    apt-get install -y --no-install-recommends \
        libgl1 \
        libglib2.0-0 \
        libsm6 \
        libxrender1 \
        libxext6 \
        libxtst6 \
        libxcb-xinerama0 \
        xvfb \
        libglu1-mesa \
        libxcursor1 \
        libxft2 \
        libxinerama1 \
        libfltk1.3 \
        libfreetype6

    # Clean up apt cache to reduce image size
    rm -rf /var/lib/apt/lists/*

    # Install uv
    curl -LsSf https://astral.sh/uv/install.sh | \
        UV_INSTALL_DIR=/usr/local/bin sh

    # Create virtual environment with system-site-packages
    python3 -m venv --system-site-packages /opt/venv

    # Upgrade pip inside venv
    /opt/venv/bin/python -m pip install --upgrade pip

    # Install additional Python packages using uv (pointing to the venv)
    uv pip install --python /opt/venv/bin/python \
        ipykernel \
        ipywidgets \
        matplotlib \
        numpy \
        scipy \
        pyvista[jupyter] \
        meshio \
        h5py \
        jupyter \
        gmsh \
        trame \
        trame-vtk \
        trame-vuetify \
        trame-client \
        trame-jupyter-extension \
        ipyvtklink

    # Verify installation
    /opt/venv/bin/python -c "import dolfinx; print('DOLFINx version:', dolfinx.__version__)"
    /opt/venv/bin/python -c "import pyvista; print('PyVista version:', pyvista.__version__)"
    /opt/venv/bin/python -c "import gmsh; print('Gmsh module loaded')"
    /opt/venv/bin/python -c "import trame; print('Trame loaded')"